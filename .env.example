# ── LLM ──────────────────────────────────────────────────────────────────────
# Supported values: claude, openai  (default: claude)
LLM_PROVIDER=claude

# Claude (required when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6        # optional, default: claude-opus-4-6

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o                    # optional, default: gpt-4o

# Gemini (required when LLM_PROVIDER=gemini)
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash          # optional, default: gemini-1.5-flash

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...               # Socket Mode app-level token
SLACK_ALERT_CHANNEL=C...               # Channel ID that receives Airflow alerts
SLACK_AIRFLOW_BOT_USER=U...            # (optional) User ID of the Airflow notification bot
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...  # Airflow on_failure_callback용 Incoming Webhook
